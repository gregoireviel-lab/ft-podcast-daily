# Firebase Web SDK (Client-side) — Projet Firebase: ft-podcast-daily
# Ces clés sont PUBLIQUES (NEXT_PUBLIC_) car lues côté client
# À récupérer dans Firebase Console > Project Settings > Web App

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=ft-podcast-daily.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=ft-podcast-daily
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=ft-podcast-daily.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
