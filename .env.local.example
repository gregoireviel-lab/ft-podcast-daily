# Neon Postgres — episode metadata (server-side only, NOT NEXT_PUBLIC_)
# The pipeline (~/projects/analysis/ft-podcast-daily) writes rows here;
# this app reads them in Server Components / ISR.
# Get it from the Neon console (project: ft-podcast-daily) or `vercel env pull`.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
